# Worker image for nfind: runs an LLM-generated filter against a read-only
# /data mount. The worker uses only the Python standard library, so no pip
# installs are needed. Build context is the package directory, which contains
# worker.py alongside this Dockerfile.
FROM python:3.11-slim

# Run as an unprivileged user; the container additionally drops all Linux
# capabilities and disables networking at run time (see execution.run_filter).
RUN useradd --create-home --uid 10001 worker

COPY worker.py /app/worker.py

USER worker
WORKDIR /app

# Reads a JSON request on stdin, writes a JSON response on stdout.
ENTRYPOINT ["python", "/app/worker.py", "--worker"]
